# SuperBad Lite — environment variables
#
# Copy to `.env.local` for local development. Production env lives in the
# hosting platform (Coolify) — never commit real secrets to the repo.
#
# Every variable here is validated at boot in `lib/env.ts`. Missing or
# malformed values fail loudly on `next dev` / `next build` startup.

# Public application URL (browser-visible). Local dev uses port 3001 to
# avoid clashing with HQ on port 3000.
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Auth.js v5 callback origin. Wired in Wave 1 A8. Must match the public
# URL above in every environment.
NEXTAUTH_URL="http://localhost:3001"

# Auth.js v5 session secret. Generate with: `openssl rand -base64 32`
# Wave 1 A8 will start consuming this; A1 only declares + validates.
NEXTAUTH_SECRET=""

# SQLite database path. Local dev uses a file in the repo root; production
# points at the Litestream-replicated file on Coolify's attached volume.
DATABASE_URL="file:./dev.db"

# Resend — transactional + outreach email adapter (A7+).
# Get from https://resend.com/api-keys. Must be verified domain sender.
RESEND_API_KEY=""
EMAIL_FROM="andy@superbadmedia.com.au"
EMAIL_FROM_NAME="Andy Robinson — SuperBad"

# Stripe — customer + invoicing + subscriptions (A7+).
# Use sk_test_... in dev, sk_live_... only in Coolify production env.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Anthropic — LLM calls gated by lib/kill-switches.ts (A7+).
# All LLM calls route through lib/ai/models.ts — never hardcode model IDs.
ANTHROPIC_API_KEY=""

# Brand DNA Gate bypass (A8+).
# Dev/test escape hatch only. Post-BDA-4, production relies on the NextAuth
# jwt callback (`lib/auth/auth.ts`) to flip `token.brand_dna_complete=true`
# once Andy's SuperBad-self profile reaches `status='complete'` — no bypass
# needed for day-to-day admin access.
# Still useful for: (a) local dev before the assessment is seeded, (b) the
# INCIDENT_PLAYBOOK.md recovery path if the gate misfires and locks Andy out.
# NEVER set to "true" in production long-term — it disables a security gate.
# See FOUNDATIONS.md §11.8 and INCIDENT_PLAYBOOK.md (Phase 6) for rollback notes.
BRAND_DNA_GATE_BYPASS=""

# Sentry — error tracking + cost-alert emails (B1+).
# Get DSN from https://sentry.io (Settings > Projects > Client Keys).
# NEXT_PUBLIC_SENTRY_DSN is browser-visible. SENTRY_DSN is server/edge only.
# Events are suppressed until the `sentry_enabled` kill-switch is on — safe
# to set the DSN in dev without sending noise to Sentry.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Used by the Sentry webpack plugin for source-map uploads (build time only).
# Leave blank to skip source-map upload in local dev.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Credential vault — AES-256-GCM symmetric encryption (B2+).
# Used to encrypt sensitive secrets stored in the database (API keys, tokens).
# Generate with: openssl rand -hex 32
# NEVER commit a real key. Rotate procedure: INCIDENT_PLAYBOOK.md §4.
CREDENTIAL_VAULT_KEY=""

# Cloudflare R2 — Litestream SQLite backup destination (B2+).
# Litestream config: litestream.yml. Restore procedure: docs/dr-runbook.md.
# R2_ENDPOINT_URL format: https://<account_id>.r2.cloudflarestorage.com
# ATO 7-year retention: configure the R2 bucket with no-expire lifecycle rules.
R2_BUCKET_NAME=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT_URL=""
# DB_FILE_PATH is the raw filesystem path to the SQLite file (no "file:" prefix).
# Matches the location of DATABASE_URL on the Coolify persistent volume.
# Example production value: /data/db.sqlite
DB_FILE_PATH="./dev.db"

# Geo IP detection — cookie consent banner EU gate (B3+).
# GEOIP_TEST_EU_IPS: comma-separated IPs that are treated as EU (test/dev use only).
# Example: GEOIP_TEST_EU_IPS="212.58.244.1,195.148.127.0"
# Production uses ip-api.com free HTTP lookup (no key required).
# PATCHES_OWED: b3_maxmind_stub — upgrade to MaxMind GeoLite2 binary DB at Phase 6.
GEOIP_TEST_EU_IPS=""
