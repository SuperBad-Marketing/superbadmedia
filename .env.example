# SuperBad Lite — environment variables
#
# Copy to `.env.local` for local development. Production env lives in the
# hosting platform (Coolify) — never commit real secrets to the repo.
#
# Every variable here is validated at boot in `lib/env.ts`. Missing or
# malformed values fail loudly on `next dev` / `next build` startup.

# Public application URL (browser-visible). Local dev uses port 3001 to
# avoid clashing with HQ on port 3000.
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Auth.js v5 callback origin. Wired in Wave 1 A8. Must match the public
# URL above in every environment.
NEXTAUTH_URL="http://localhost:3001"

# Auth.js v5 session secret. Generate with: `openssl rand -base64 32`
# Wave 1 A8 will start consuming this; A1 only declares + validates.
NEXTAUTH_SECRET=""

# SQLite database path. Local dev uses a file in the repo root; production
# points at the Litestream-replicated file on Coolify's attached volume.
DATABASE_URL="file:./dev.db"

# Resend — transactional + outreach email adapter (A7+).
# Get from https://resend.com/api-keys. Must be verified domain sender.
RESEND_API_KEY=""
EMAIL_FROM="andy@superbadmedia.com.au"
EMAIL_FROM_NAME="Andy Robinson — SuperBad"
# Resend webhook signing secret (Svix-compatible). Get from
# https://resend.com/webhooks after creating an endpoint pointed at
# `{APP_URL}/api/resend/webhook`. Consumed by the SP-8 receiver.
RESEND_WEBHOOK_SECRET=""

# Stripe — customer + invoicing + subscriptions (A7+).
# Use sk_test_... in dev, sk_live_... only in Coolify production env.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Publishable key exposed to the browser for Payment Element (QB-4c).
# Safely equal to STRIPE_PUBLISHABLE_KEY — publishable keys are public.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SuperBad Media supplier profile — rendered on branded invoices
# (BI-1b / BI-2b). All five are read with "To be confirmed" / fallback
# string defaults; the PDF template and the client invoice web view
# ship a literal "ABN to confirm" until these are populated in Coolify
# production env. Pre-launch: set all five before the first paid
# invoice leaves the platform.
#   SUPERBAD_ABN: 11-digit ABN without spaces, e.g. 12345678901.
#   SUPERBAD_BILLING_EMAIL: reply-to address on invoice threads.
#   SUPERBAD_BANK_ACCOUNT_NAME / _BSB / _ACCOUNT_NUMBER: bank-transfer
#     details surfaced in the admin bank-details card (BI-2a) and the
#     public invoice payment section (BI-2b).
SUPERBAD_ABN=""
SUPERBAD_BILLING_EMAIL="hi@superbadmedia.com.au"
SUPERBAD_BANK_ACCOUNT_NAME=""
SUPERBAD_BANK_BSB=""
SUPERBAD_BANK_ACCOUNT_NUMBER=""

# Stripe TEST-mode key used **only** by the Playwright E2E smoke
# (`tests/e2e/critical-flight-stripe.spec.ts`). If unset, the E2E spec
# calls `test.skip()` — the scaffold stays green in CI without a real key.
# Must be an `sk_test_...` key that can `balance.retrieve()`; never a live
# key. Scoped to the E2E job; not read anywhere in app code.
STRIPE_TEST_KEY=""

# Resend TEST-mode key used **only** by the Playwright E2E smoke
# (`tests/e2e/critical-flight-resend.spec.ts`). If unset, the E2E spec
# calls `test.skip()` — the scaffold stays green in CI without a real key.
# Must be a Resend key that can `apiKeys.list()`; scoped to the E2E job;
# not read anywhere in app code.
RESEND_TEST_KEY=""

# Microsoft Graph — admin mail + calendar (SW-7) + Unified Inbox sync (UI-1).
# Register an Azure app (Entra ID → App registrations) to populate:
#   MS_GRAPH_CLIENT_ID: the Application (client) ID.
#   MS_GRAPH_CLIENT_SECRET: the Client secret (Certificates & secrets → New).
#   MS_GRAPH_TENANT_ID: the Directory (tenant) ID, or "common" for multi-tenant.
# Redirect URI to whitelist in Azure: <NEXT_PUBLIC_APP_URL>/api/oauth/graph-api/callback
# Required scopes: offline_access User.Read Mail.ReadWrite Mail.Send MailboxSettings.Read Calendars.Read
# Left blank until Andy registers the app; the wizard's authorize URL falls
# back to "#" and the graph-api-admin E2E stays on the direct-token path.
MS_GRAPH_CLIENT_ID=""
MS_GRAPH_CLIENT_SECRET=""
MS_GRAPH_TENANT_ID=""

# Graph TEST-mode access token used **only** by the Playwright E2E smoke
# (`tests/e2e/critical-flight-graph.spec.ts`). If unset, the E2E spec calls
# `test.skip()`. When set, the spec injects the token directly via the
# wizard's ?testToken=… path (gated on NODE_ENV !== "production" server-
# side). Must be a valid access_token that can call `GET /v1.0/me`.
GRAPH_TEST_TOKEN=""

# Meta Ads (Facebook Marketing API) — admin ad account access (SW-10).
# Register a Meta app (https://developers.facebook.com/apps) to populate:
#   META_ADS_CLIENT_ID: the App ID.
#   META_ADS_CLIENT_SECRET: the App Secret (used by SW-10-b for the token
#     exchange; unused by the SW-10-a skeleton).
# Redirect URI to whitelist on the Meta app:
#   <NEXT_PUBLIC_APP_URL>/api/oauth/meta-ads/callback
# Left blank until Andy registers the app; the wizard's authorize URL falls
# back to "#" and the meta-ads E2E stays on the direct-token path.
META_ADS_CLIENT_ID=""
META_ADS_CLIENT_SECRET=""

# Meta Ads TEST-mode access token used **only** by the Playwright E2E smoke
# (`tests/e2e/admin-meta-ads.spec.ts`). If unset, the E2E spec calls
# `test.skip()`. When set, the spec injects the token directly via the
# wizard's ?testToken=… path (gated on NODE_ENV !== "production" server-
# side). Must be a valid Meta access token that can call `GET /v20.0/me`.
META_ADS_TEST_TOKEN=""

# Google Ads (Google Ads API) — admin ad account access (SW-11).
# Register a Google Cloud app (https://console.cloud.google.com/apis/credentials)
# with OAuth consent screen configured + Ads API enabled. Populate:
#   GOOGLE_ADS_CLIENT_ID: the OAuth 2.0 Client ID.
#   GOOGLE_ADS_CLIENT_SECRET: the OAuth 2.0 Client secret (used by SW-11-b
#     for the token exchange; unused by the SW-11-a skeleton).
# Redirect URI to whitelist on the Google Cloud app:
#   <NEXT_PUBLIC_APP_URL>/api/oauth/google-ads/callback
# NOTE: Google Ads **API calls** (not OAuth, not /userinfo) also require a
# `developer-token` HTTP header issued by Google to the MCC account. Feature-
# session concern; the wizard's identity ping is plain bearer-only.
# Left blank until Andy registers the app; the wizard's authorize URL falls
# back to "#" and the google-ads E2E stays on the direct-token path.
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""

# Google Ads TEST-mode access token used **only** by the Playwright E2E smoke
# (`tests/e2e/admin-google-ads.spec.ts`). If unset, the E2E spec calls
# `test.skip()`. When set, the spec injects the token directly via the
# wizard's ?testToken=… path (gated on NODE_ENV !== "production" server-
# side). Must be a valid Google access token that can call
# `GET https://www.googleapis.com/oauth2/v3/userinfo`.
GOOGLE_ADS_TEST_TOKEN=""

# Twilio (SW-12) — SMS / WhatsApp channel. Unlike Meta and Google, Twilio has
# no app-registration step: admins paste an Account SID + Auth Token straight
# from the Twilio console. The wizard verifies by hitting
# `GET https://api.twilio.com/2010-04-01/Accounts/<SID>.json` with HTTP Basic
# auth. No CLIENT_ID / CLIENT_SECRET pair owed.
#
# TWILIO_TEST_SID + TWILIO_TEST_TOKEN are consumed **only** by the Playwright
# E2E smoke (`tests/e2e/admin-twilio.spec.ts`); the spec `test.skip()`s when
# either is unset. The test types the real credentials into the form step
# and the celebration orchestrator runs a live account ping.
TWILIO_TEST_SID=""
TWILIO_TEST_TOKEN=""

# Generic API-key wizard TEST-mode credentials (SW-13). Consumed **only**
# by `tests/e2e/admin-api-key-*.spec.ts` — each vendor's E2E `test.skip()`s
# when its TEST_KEY is unset, keeping CI green without real keys. Scoped
# to the E2E job; not read anywhere in app code. The wizard itself stores
# credentials vault-encrypted in `integration_connections`, so these env
# vars are purely the test-harness path.
#   OPENAI_TEST_KEY    — can call GET https://api.openai.com/v1/models
#   ANTHROPIC_TEST_KEY — can call GET https://api.anthropic.com/v1/models
#   SERPAPI_TEST_KEY   — can call GET https://serpapi.com/account
#   REMOTION_TEST_KEY  — Remotion commercial licence key (no live verify)
OPENAI_TEST_KEY=""
ANTHROPIC_TEST_KEY=""
SERPAPI_TEST_KEY=""
REMOTION_TEST_KEY=""

# Anthropic — LLM calls gated by lib/kill-switches.ts (A7+).
# All LLM calls route through lib/ai/models.ts — never hardcode model IDs.
ANTHROPIC_API_KEY=""

# Brand DNA Gate bypass (A8+).
# Dev/test escape hatch only. Post-BDA-4, production relies on the NextAuth
# jwt callback (`lib/auth/auth.ts`) to flip `token.brand_dna_complete=true`
# once Andy's SuperBad-self profile reaches `status='complete'` — no bypass
# needed for day-to-day admin access.
# Still useful for: (a) local dev before the assessment is seeded, (b) the
# INCIDENT_PLAYBOOK.md recovery path if the gate misfires and locks Andy out.
# NEVER set to "true" in production long-term — it disables a security gate.
# See FOUNDATIONS.md §11.8 and INCIDENT_PLAYBOOK.md (Phase 6) for rollback notes.
BRAND_DNA_GATE_BYPASS=""

# Sentry — error tracking + cost-alert emails (B1+).
# Get DSN from https://sentry.io (Settings > Projects > Client Keys).
# NEXT_PUBLIC_SENTRY_DSN is browser-visible. SENTRY_DSN is server/edge only.
# Events are suppressed until the `sentry_enabled` kill-switch is on — safe
# to set the DSN in dev without sending noise to Sentry.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Used by the Sentry webpack plugin for source-map uploads (build time only).
# Leave blank to skip source-map upload in local dev.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Credential vault — AES-256-GCM symmetric encryption (B2+).
# Used to encrypt sensitive secrets stored in the database (API keys, tokens).
# Generate with: openssl rand -hex 32
# NEVER commit a real key. Rotate procedure: INCIDENT_PLAYBOOK.md §4.
CREDENTIAL_VAULT_KEY=""

# Cloudflare R2 — Litestream SQLite backup destination (B2+).
# Litestream config: litestream.yml. Restore procedure: docs/dr-runbook.md.
# R2_ENDPOINT_URL format: https://<account_id>.r2.cloudflarestorage.com
# ATO 7-year retention: configure the R2 bucket with no-expire lifecycle rules.
R2_BUCKET_NAME=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT_URL=""
# DB_FILE_PATH is the raw filesystem path to the SQLite file (no "file:" prefix).
# Matches the location of DATABASE_URL on the Coolify persistent volume.
# Example production value: /data/db.sqlite
DB_FILE_PATH="./dev.db"

# Puppeteer (QB-3) — PDF rendering for quote PDFs and any future
# render-to-PDF surfaces. Uses `puppeteer-core`, which does NOT bundle
# Chromium — provide a path to an existing Chrome/Chromium binary.
#
# Defaults if unset:
#   - macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   - Linux (production / Coolify): /usr/bin/google-chrome-stable
# Set explicitly for any other platform or non-default install location.
PUPPETEER_EXECUTABLE_PATH=""

# Geo IP detection — cookie consent banner EU gate (B3+).
# GEOIP_TEST_EU_IPS: comma-separated IPs that are treated as EU (test/dev use only).
# Example: GEOIP_TEST_EU_IPS="212.58.244.1,195.148.127.0"
# Production uses ip-api.com free HTTP lookup (no key required).
# PATCHES_OWED: b3_maxmind_stub — upgrade to MaxMind GeoLite2 binary DB at Phase 6.
GEOIP_TEST_EU_IPS=""
